# --- Robot Status API (Render) ---
# Base URL for the /heartbeat and /telemetry endpoints. Provided at the start
# of the technical segment.
ROBOT_API_BASE_URL=

# --- Supabase ---
# Used to read the seed data and persist the latest computed status. The app
# falls back to the bundled sample dataset (src/data/sample-robots.json) when
# these are unset, so it runs with zero configuration.
#
# Copy this file to .env.local and fill in your project values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
